# Music Recommender: Music Theory — environment variables
# Copy this file to .env and fill in real values.

# Required: Anthropic API key (used for Gatekeeper moderation, Prestige explanations,
# Hertz critique, and Maestro reranking — all LLM calls go through this key).
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Required: Last.fm API key (used by Misty for track retrieval).
# Register at: https://www.last.fm/api/account/create
LASTFM_API_KEY=your_lastfm_api_key_here

# Optional: MeloData API key (used for MasterMix BPM enrichment).
# When present, the retrieval phase will call MeloData to populate SongFeature.bpm
# with high-accuracy BPM values via real audio analysis (Essentia engine).
# Without this key, --mastermix activates but the BPM filter has no effect —
# all candidates are treated as neutral. Free tier: 1,000 lookups/month.
# Register at: https://melodata.io
MELODATA_API_KEY=your_melodata_api_key_here
